# Deribit API credentials
DERIBIT_CLIENT_ID=your_client_id
DERIBIT_CLIENT_SECRET=your_client_secret

# Environment: "test" (test.deribit.com) or "prod" (deribit.com)
DERIBIT_ENV=test

# Option expiry targeting
TARGET_DTE=0
DTE_TOLERANCE=1

# Position sizing (fraction of account equity per straddle)
EQUITY_PCT=0.20

# Tiered exit: fraction of total contracts for Tier 1 TP
TIER1_FRACTION=0.20

# Tier 1 take-profit: 50% gain on combined straddle premium
TAKE_PROFIT_PCT=0.50

# Tier 2 time-based exit (UTC)
EXIT_HOUR_UTC=18
EXIT_MINUTE_UTC=0

# Entry protection: abort if either leg fills >50% above cached ask
ENTRY_CAP_PCT=0.50
MAX_ENTRY_ATTEMPTS=2

# Order execution
MAX_ORDER_RETRIES=3
ALLOW_MARKET_FALLBACK=true
